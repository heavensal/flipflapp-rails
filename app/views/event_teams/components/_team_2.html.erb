  <!-- Team B -->
  <div class="rounded-2xl bg-team-b/90 backdrop-blur-md shadow-md p-3 flex flex-col gap-2">
    <%= render "event_teams/components/countable_team_heading", event: event, team: team_2 %>

    <div class="flex flex-col gap-1">
      <% if team_2.event_participants.empty? %>
        <p class="text-center text-gray-400">Aucun joueur dans cette équipe</p>
      <% end %>
      <% team_2.event_participants.each do |event_participant| %>
        <%= render 'event_participants/one_player_team_2_card', event_participant: event_participant %>
      <% end %>
    </div>

    <% unless team_2.in_this_team?(current_user) %>
      <% if team_2.joinable? %>
        <div class="mt-auto">
          <%= render 'event_participants/form_btn', event: event, team: team_2 %>
        </div>
      <% end %>
    <% end %>
  </div>
