  <!-- Team B -->
  <div class="rounded-2xl bg-team-b/90 backdrop-blur-md shadow-md p-3 flex flex-col gap-2">
    <%= render "event_teams/components/countable_team_heading", event: event, team: team_2 %>

    <% participants = team_2.event_participants %>
    <p class="text-center text-xs text-white/70">
      <%= participants.size %>/<%= team_2.capacity %>
    </p>

    <div class="flex flex-col gap-1">
      <% if participants.empty? %>
        <p class="text-center text-gray-400"><%= t("event_participants.teams.empty") %></p>
      <% end %>
      <% participants.each do |event_participant| %>
        <%= render 'event_participants/one_player_team_2_card', event_participant: event_participant %>
      <% end %>
    </div>

    <% unless team_2.in_this_team?(current_user) %>
      <% if team_2.joinable? %>
        <div class="mt-auto">
          <%= render 'event_participants/form_btn', event: event, team: team_2, switching: event.in_this_event?(current_user) %>
        </div>
      <% end %>
    <% end %>
  </div>
