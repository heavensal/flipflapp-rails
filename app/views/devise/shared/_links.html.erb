<div class="flex flex-col space-y-4 mt-6">
  <%- if controller_name != 'sessions' %>
    <%= link_to t(".sign_in"), new_session_path(resource_name),
        class: "text-secondary-text transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div class="gap-2">
      <span class="text-secondary-text block"><%= t(".sign_up_prompt") %></span>
      <%= link_to t(".sign_up"), new_registration_path(resource_name),
          class: "text-primary-yellow font-semibold transition-colors" %>
    </div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to t(".forgot_password"), new_password_path(resource_name),
        class: "text-indigo-100/60 text-sm transition-colors" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to t(".resend_confirmation"), new_confirmation_path(resource_name),
        class: "text-indigo-100/60 text-sm transition-colors" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to t(".resend_unlock"), new_unlock_path(resource_name),
        class: "text-indigo-100/60 text-sm transition-colors" %>
  <% end %>
</div>
