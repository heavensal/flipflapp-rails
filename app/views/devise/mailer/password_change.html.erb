<%= content_for :title do %>
  <%= t(".title") %>
<% end %>

<h1><%= t(".greeting", first_name: @resource.first_name) %><br><%= t(".headline") %></h1>

<p><%= t(".body") %></p>

<p><%= t(".source") %></p>

<p class="action">
  <%= link_to t(".cta"), unauthenticated_root_url, class: "btn" %>
</p>

<p class="note"><%= t(".warning") %></p>
