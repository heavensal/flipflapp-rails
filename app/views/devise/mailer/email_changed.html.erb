<%= content_for :title do %>
  <%= t(".title") %>
<% end %>

<h1><%= t(".greeting", first_name: @resource.first_name) %><br><%= t(".headline") %></h1>

<% if @resource.try(:unconfirmed_email?) %>
  <p><%= t(".pending_body", email: @resource.unconfirmed_email) %></p>

  <p><%= t(".pending_note") %></p>
<% else %>
  <p><%= t(".confirmed_body", email: @resource.email) %></p>

  <p><%= t(".confirmed_note") %></p>
<% end %>

<p style="text-align: center;">
  <%= link_to t(".cta"), unauthenticated_root_url, class: "btn" %>
</p>

<p style="text-align: center;"><%= t(".warning") %></p>
