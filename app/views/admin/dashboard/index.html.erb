<main class="min-h-dvh text-white px-4 py-8 max-w-5xl mx-auto">
  <h1 class="text-3xl font-bold mb-2"><%= t("admin.titles.dashboard") %></h1>
  <p class="text-white/70 mb-8"><%= t("admin.labels.subtitle") %></p>

  <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <% @resources.each do |resource| %>
      <% entry = Admin::Resource.new(resource) %>
      <%= link_to entry.admin_index_path(self),
                  class: "rounded-2xl bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition" do %>
        <h2 class="text-xl font-semibold text-amber-400"><%= admin_model_name(entry) %></h2>
        <p class="text-sm text-white/60 mt-1">
          <%= t("admin.labels.record_count", count: entry.model_class.count) %>
        </p>
      <% end %>
    <% end %>
  </section>
</main>
