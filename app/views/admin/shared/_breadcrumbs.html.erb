<nav class="text-sm text-white/60 mb-6" aria-label="<%= t("admin.titles.breadcrumbs") %>">
  <%= link_to t("admin.navigation.home"), admin_root_path, class: "hover:text-amber-400" %>
  <span class="mx-2">/</span>
  <%= link_to admin_model_name(resource), resource.admin_index_path(self), class: "hover:text-amber-400" %>
  <% if local_assigns[:record] %>
    <span class="mx-2">/</span>
    <span class="text-white"><%= resource.record_label(record) %></span>
  <% end %>
</nav>
