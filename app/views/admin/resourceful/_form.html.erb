<%= form_with model: [ :admin, record ], class: "space-y-4" do |form| %>
  <% if record.errors.any? %>
    <div class="rounded-lg bg-red-900/40 border border-red-500 p-4" role="alert">
      <ul class="list-disc list-inside text-sm">
        <% record.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% resource.writable_columns.each do |column| %>
    <div>
      <%= form.label column, class: "block text-sm text-white/70 mb-1" %>
      <%= admin_field_for(form, resource, column) %>
    </div>
  <% end %>

  <% if record.is_a?(User) && record.new_record? %>
    <div>
      <%= form.label :password, class: "block text-sm text-white/70 mb-1" %>
      <%= form.password_field :password, class: admin_input_classes %>
    </div>
    <div>
      <%= form.label :password_confirmation, class: "block text-sm text-white/70 mb-1" %>
      <%= form.password_field :password_confirmation, class: admin_input_classes %>
    </div>
  <% end %>

  <div class="flex gap-3 pt-4">
    <%= form.submit class: "px-4 py-2 rounded-lg bg-amber-500 text-black font-semibold hover:bg-amber-400 cursor-pointer" %>
    <%= link_to t("admin.actions.cancel"), resource.admin_index_path(self),
                class: "px-4 py-2 rounded-lg border border-white/30 hover:bg-white/10" %>
  </div>
<% end %>
