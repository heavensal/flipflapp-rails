<% invited_user = invitation.user %>
<% is_me = invited_user == current_user %>

<%= link_to is_me ? me_path : user_path(invited_user) do %>
  <div class="flex items-center gap-2 rounded-lg px-4 py-2 shadow bg-linear-to-r from-amber-400/10 to-amber-600/10">
    <div class="w-8 h-8 rounded-full bg-linear-to-tr from-amber-600 to-amber-400 flex items-center justify-center text-white font-bold shadow <%= is_me ? "border-amber-400 border" : "" %>">
      <% if invited_user.avatar? %>
        <%= cl_image_tag invited_user.avatar, class: "h-8 w-8 rounded-full object-cover" %>
      <% else %>
        <span class="text-sm"><%= invited_user.first_name.first.upcase %></span>
      <% end %>
    </div>

    <span class="text-white">
      <%= invited_user.first_name %>
    </span>
  </div>
<% end %>
