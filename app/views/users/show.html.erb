<main class="min-h-dvh text-white px-4 py-8">
  <div class="max-w-2xl mx-auto">

    <!-- Header de profil -->
    <section class="text-center mb-8">
      <!-- Avatar principal -->
      <div class="inline-block mb-6">
        <div class="size-32 rounded-full bg-linear-to-tr from-amber-400 to-amber-600 p-1 shadow-xl">
          <div class="w-full h-full rounded-full overflow-hidden bg-linear-to-br from-bg-green to-bg-green-2 flex items-center justify-center">
            <% if @user.avatar? %>
              <%= cl_image_tag @user.avatar, class: "w-full h-full object-cover rounded-full" %>
            <% else %>
              <svg width="64" height="64" viewBox="0 0 0.6 0.6" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="text-gray-400">
                <path d="M.44.06a.06.06 0 1 1-.12 0 .06.06 0 0 1 .12 0m0 .38a.04.04 0 1 0 0 .08.04.04 0 0 0 0-.08M.514.244.438.168A.02.02 0 0 0 .423.161H.14a.02.02 0 0 0 0 .04h.108L.12.452V.46a.02.02 0 0 0 .04.008L.2.4h.08L.203.57.2.58a.02.02 0 0 0 .04.008L.428.213l.058.059A.02.02 0 0 0 .514.244"/>
              </svg>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Nom et username -->
      <h1 class="text-4xl font-extrabold tracking-tight mb-2">
        <%= @user.first_name %> <%= @user.last_name %>
      </h1>
      <p class="text-secondary-text text-xl mb-4">@<%= @user.username %></p>
    </section>

    <!-- Actions -->
    <section id="actions-btn" class="text-center mb-8">

<%# si c'est moi même %>
      <% if current_user == @user %>
        <%= link_to edit_user_registration_path, class: "inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary-yellow text-white font-bold shadow-lg hover:bg-yellow-600 transition-all duration-200" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          <%= t("users.actions.edit_profile") %>
        <% end %>

<%# si c'est un autre user, que je n'ai pas en ami %>
      <% elsif @friendship.blank? %>
        <%= button_to friendships_path, params: { user_id: @user.id }, class: "inline-flex items-center gap-2 btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          <%= t("users.actions.add_friend") %>
        <% end %>

<%# Si il m'a demande en ami et que je n'ai pas encore accepté %>
    <%# je peux accepter %>
      <% elsif @friendship.sender == @user && @friendship.receiver == current_user && @friendship.status == "pending" %>
        <%= button_to friendship_path(@friendship), method: :patch, class: "inline-flex items-center gap-2 btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <%= t("users.actions.accept_request") %>
        <% end %>

    <%# ou je peux refuser %>
        <%= link_to friendship_path(@friendship), class: "inline-flex items-center gap-2 px-6 py-3 rounded-full bg-red-600 text-white font-bold shadow-lg hover:bg-red-700 transition-all duration-200", data: { turbo_method: :delete, turbo_confirm: t("users.confirms.decline") } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          <%= t("users.actions.decline_request") %>
        <% end %>

<%# Si j'ai demande en ami et que je n'ai pas encore été accepté %>
    <%# je peux annuler %>
      <% elsif @friendship.sender == current_user && @friendship.receiver == @user && @friendship.status == "pending" %>
        <%= link_to friendship_path(@friendship), class: "inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gray-700 text-white font-bold shadow-lg hover:bg-gray-600 transition-all duration-200", data: { turbo_method: :delete, turbo_confirm: t("users.confirms.cancel") } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <%= t("users.actions.cancel_request") %>
        <% end %>

<%# Si on est deja amis %>
    <%# je peux le supprimer %>
      <% elsif @friendship.status == "accepted" %>
        <%= link_to friendship_path(@friendship), class: "inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gray-700 text-white font-bold shadow-lg hover:bg-gray-600 transition-all duration-200", data: { turbo_method: :delete, turbo_confirm: t("users.confirms.remove") } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= t("users.actions.remove_friend") %>
        <% end %>

      <% end %>
    </section>

    <!-- Informations du profil -->
    <section class="mb-8">
      <div class="rounded-2xl bg-white/5 backdrop-blur-md shadow-xl p-6">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary-text" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <%= t("users.titles.info") %>
        </h2>

        <div class="space-y-3">
          <% if current_user == @user %>
            <div class="flex justify-between items-center">
              <span class="text-indigo-100/60"><%= t("users.labels.email") %></span>
              <span class="font-medium"><%= @user.email %></span>
            </div>
          <% end %>

          <div class="flex justify-between items-center">
            <span class="text-indigo-100/60"><%= t("users.labels.role") %></span>
            <span class="bg-form-green/80 px-2 py-1 rounded-full text-xs font-semibold">
              <%= @user.role == "admin" ? t("users.labels.role_admin") : t("users.labels.role_player") %>
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-indigo-100/60"><%= t("users.labels.member_since") %></span>
            <span class="font-medium"><%= human_future_date(@user.created_at) %></span>
          </div>
        </div>
      </div>
    </section>

  </div>
</main>
