<%= turbo_frame_tag "events" do %>
  <section class="grid grid-cols-1 space-y-2" id="events" data-turbo-permanent>
    <% if @events.empty? %>
    <section class="text-center py-12" aria-live="polite">
      <p class="text-indigo-100/60 text-lg" role="status"><%= t("events.empty.index") %></p>
      <%= link_to t("events.actions.create_first"), new_event_path,
          class: "inline-block mt-4 px-4 py-2 bg-form-green text-white rounded-lg transition-colors",
          role: "button",
          aria_label: t("events.actions.create_first"),
          data: { turbo_frame: "_top" } %>
    </section>
    <% end %>

    <% @events.each do |event| %>
      <%= render "events/components/one_event_card", event: event %>
    <% end %>
  </section>
<% end %>
