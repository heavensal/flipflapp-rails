<%= form_for event, html: { class: "space-y-4" } do |f| %>
  <div>
    <%= f.label :title, class: "block text-secondary-text mb-2" %>
    <%= f.text_field :title, class: "form-text-input", placeholder: t("events.form.placeholders.title"), required: true %>
  </div>

  <div data-controller="maps--autocomplete">
    <%= f.label :location, class: "block text-secondary-text mb-2" %>
    <%= f.text_field :location, class: "form-text-input", placeholder: t("events.form.placeholders.location"), required: true, data: { maps__autocomplete_target: "address" } %>
    <%= f.hidden_field :latitude, id: "event_latitude", class: "form-text-input", placeholder: "48.8566", required: true, data: { maps__autocomplete_target: "latitude" } %>
    <%= f.hidden_field :longitude, id: "event_longitude", class: "form-text-input", placeholder: "2.3522", required: true, data: { maps__autocomplete_target: "longitude" } %>
  </div>

  <div>
    <%= f.label :start_time, class: "block text-secondary-text mb-2" %>
    <%= f.datetime_field :start_time, class: "form-text-input", required: true %>
  </div>

  <div>
    <%= f.label :number_of_participants, class: "block text-secondary-text mb-2" %>
    <%= f.number_field :number_of_participants, class: "form-text-input", placeholder: "10", step: 1, required: true %>
  </div>

  <div>
    <%= f.label :price, class: "block text-secondary-text mb-2" %>
    <div class="relative">
      <%= f.number_field :price,
            class: "form-text-input pr-10",
            step: 1,
            min: 0,
            value: (f.object.price.present? ? format("%.2f", f.object.price) : nil),
            placeholder: "10.00",
            required: true %>
      <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-secondary-text" aria-hidden="true">€</span>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-secondary-text mb-2" %>
    <%= f.text_area :description, class: "form-text-input", placeholder: t("events.form.placeholders.description") %>
  </div>

  <div>
    <%= f.label :is_private, class: "block text-secondary-text mb-2" %>
    <%= f.check_box :is_private, class: "form-checkbox" %>
  </div>

  <div class="mt-6 flex justify-between">
    <%= link_to t(cancel_key), cancel_path, class: "bg-gray-500 text-indigo-100 py-2 px-4 min-w-1/3 text-center" %>
    <%= f.submit t(submit_key), class: "py-2 px-4 min-w-1/3 bg-primary-yellow text-white py-2 font-semibold transition active:scale-95 active:bg-yellow-500 disabled:opacity-50 disabled:cursor-wait" %>
  </div>
<% end %>
