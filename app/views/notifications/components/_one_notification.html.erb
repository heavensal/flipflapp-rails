<%# locals: notification %>
<div class="grid grid-cols-12 gap-2 items-center p-2 mb-2 rounded-lg <%= notification_row_classes(notification) %>">
  <div class="col-span-1 flex items-center justify-center">
    <div class="w-8 h-8 flex items-center justify-center rounded-full <%= notification_icon_classes(notification.kind) %>">
      <%= notification_icon(notification.kind) %>
    </div>
  </div>

  <div class="col-span-8 min-w-0">
    <% if notification.clickable? %>
      <%= link_to read_notification_path(notification, navigate: 1),
                  class: "block",
                  data: { turbo_method: :patch, turbo_frame: "_top" } do %>
        <p class="text-sm font-medium text-secondary-text"><%= notification_message(notification) %></p>
        <p class="text-xs text-indigo-100/60">
          <%= t("notifications.labels.time_ago", time: time_ago_in_words(notification.created_at)) %>
        </p>
      <% end %>
    <% else %>
      <p class="text-sm font-medium text-secondary-text"><%= notification_message(notification) %></p>
      <p class="text-xs text-indigo-100/60">
        <%= t("notifications.labels.time_ago", time: time_ago_in_words(notification.created_at)) %>
      </p>
    <% end %>
  </div>

  <div class="col-span-3 flex items-center justify-end gap-1">
    <% unless notification.read? %>
      <%= button_to read_notification_path(notification),
                    method: :patch,
                    class: "p-1.5 rounded-lg bg-white/10 hover:bg-white/20 text-white",
                    title: t("notifications.actions.mark_read"),
                    aria: { label: t("notifications.actions.mark_read") } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      <% end %>
    <% end %>

    <%= button_to notification_path(notification),
                  method: :delete,
                  class: "p-1.5 rounded-lg bg-white/10 hover:bg-white/20 text-white",
                  title: t("notifications.actions.delete"),
                  aria: { label: t("notifications.actions.delete") },
                  data: { turbo_confirm: t("notifications.confirms.delete") } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
    <% end %>
  </div>
</div>
