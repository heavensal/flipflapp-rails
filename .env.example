# Kamal ne charge pas .env : il lit .kamal/secrets (voir .kamal/secrets.example).
# Réutiliser ce fichier : ln -sf "$(pwd)/.env" "$(pwd)/.kamal/secrets"

NEON_DB="your_neon_db_url"

CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_MAPS_KEY="your_google_maps_key"

KAMAL_REGISTRY_PASSWORD="your_docker_registry_password"

# Requis pour Kamal / production (voir config/master.key en local)
RAILS_MASTER_KEY="your_rails_master_key"

SMTP_USERNAME="your_smtp_username"
SMTP_PASSWORD="your_smtp_password"