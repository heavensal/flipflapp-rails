# Read by Kamal (Dotenv). Copy to .kamal/secrets (gitignored).
# CI/CD template: .kamal/secrets.cd — see docs/DEPLOYMENT.md
#
# Reuse .env for local Kamal deploy (must include PRODUCTION_NEON_DB):
#   ln -sf "$(pwd)/.env" "$(pwd)/.kamal/secrets"

KAMAL_REGISTRY_PASSWORD=your_docker_registry_password
RAILS_MASTER_KEY=your_rails_master_key

# Kamal injects this into the production container only:
PRODUCTION_NEON_DB=your_production_neon_db_url

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_MAPS_KEY=your_google_maps_key
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
